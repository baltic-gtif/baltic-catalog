{
  "Name": "habitat_pg_indicator",
  "Title": "Biodiversity of Permanent Grassland",
  "Description": "indicators/habitat_and_pgtype/description.md",
  "Collections": [
    "lt_admin_amd1",
    "lt_stack_LULC",
    "habitatrawlayer",
    "habitat_typePG_lithuania",    
    "lt_gsa_connectivity_pg"
  ],
  "Disable": [
    "lt_stack_LULC",
    "habitatrawlayer"
  ],
    "Process": {
        "Name": "timeseries",
        "JsonForm": "jsonforms/habitat.json",
        "VegaDefinition": "chartdefs/vega_chart_habitat.json",
        "EndPoints": [
            {
                "Identifier": "timeseries",
                "Url": "https://eoapi.workspace.baltic-gtif.hub-otc.eox.at/vector/collections/public.lt_{{year}}_habitat_pg/items?limit=10000&filter-lang=cql2-text&filter=S_INTERSECTS(geometry,POLYGON(({{bbox.0}}%20{{bbox.1}},{{bbox.2}}%20{{bbox.1}},{{bbox.2}}%20{{bbox.3}},{{bbox.0}}%20{{bbox.3}},{{bbox.0}}%20{{bbox.1}})))",
		"Type": "application/json",
                "Method": "GET"
            }

        ]
    }

}
